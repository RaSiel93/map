#!/usr/bin/env bash
set -e

cd "$(dirname "$0")/.."

set -a
[ -f .env ] && . .env
[ -f client/.env ] && . client/.env
set +a
# Production serves API on the same origin — never bake localhost into the build
export REACT_APP_API_URL=""
export GENERATE_SOURCEMAP=false

yarn build && yarn deploy
FRONTEND_STRATEGY=upload bundle exec cap production deploy
